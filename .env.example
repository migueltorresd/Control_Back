# Base de datos PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=cambiar_en_cada_entorno
DATABASE_DATABASE=control_produccion

# Servidor
PORT=3001

# Entorno (development | production | test)
NODE_ENV=development

# CORS — URL del frontend (separar con comas si hay varios orígenes)
# CORS_ORIGIN=http://localhost:3000

# JWT (requerido en fase 2 — mínimo 32 caracteres aleatorios)
# JWT_SECRET=reemplazar_con_secreto_aleatorio_de_al_menos_32_caracteres
# JWT_EXPIRES_IN=8h

# Admin inicial (requerido para pnpm create-admin en fase 2)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=cambiar_en_primer_uso
