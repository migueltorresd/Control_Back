# Base de datos PostgreSQL
# En el stack dockerizado (compose) DATABASE_HOST lo fuerza el compose a "db";
# en desarrollo (backend en el host) se usa localhost.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=cambiar_en_cada_entorno
DATABASE_DATABASE=control_produccion

# Servidor
PORT=3001

# Entorno (development | production | test)
NODE_ENV=development

# CORS — URL del frontend (requerido; separar con comas si hay varios orígenes)
# Desarrollo: http://localhost:3000 · Producción: https://app.tudominio.com
CORS_ORIGIN=http://localhost:3000

# Dominio del reverse proxy Caddy (despliegue):
#   - Pruebas locales del stack: localhost (certificado autofirmado)
#   - Producción: app.tudominio.com (TLS automático con Let's Encrypt)
CADDY_SITE_ADDRESS=localhost

# JWT (requerido — mínimo 32 caracteres aleatorios; generar p. ej. con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=reemplazar_con_secreto_aleatorio_de_al_menos_32_caracteres
JWT_EXPIRES_IN=8h

# Admin inicial (solo lo usa el script: pnpm create-admin)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=minimo_10_caracteres

# Directorio de almacenamiento para las fotos de modelos
UPLOADS_DIR=./uploads

# Documentación API Swagger (opcional, default false en producción)
SWAGGER_ENABLED=false
